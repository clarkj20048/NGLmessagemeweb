# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string (required)
# Get this from MongoDB Atlas or your MongoDB provider
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ngl?retryWrites=true&w=majority

# Client origin for CORS (required)
# This should be your frontend URL
CLIENT_ORIGIN=https://nglmessagemeweb.vercel.app

# JWT secret for admin authentication (required)
# Use a strong random string, e.g., generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here

# Server port (optional, defaults to 5000)
PORT=5000

